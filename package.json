{
  "name": "temporal-research",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "node --env-file=.env --import tsx src/datasets/seed.ts",
    "consistency": "node --env-file=.env --import tsx src/harness/1-measurement/consistency.ts",
    "accuracy": "node --env-file=.env --import tsx src/harness/2-accuracy/accuracy.ts",
    "accuracy:replay": "node --import tsx src/harness/2-accuracy/fixtures.ts replay",
    "analyze": "node --import tsx src/analysis/overview.ts && node --import tsx src/analysis/report.ts && node --import tsx src/analysis/overview-viz.ts",
    "dev": "mastra dev",
    "typecheck": "tsc --noEmit",
    "probe": "node --env-file=.env --import tsx src/harness/probe.ts",
    "show-prompt": "node --import tsx src/harness/show-prompt.ts",
    "preferences": "node --env-file=.env --import tsx src/harness/1-measurement/preferences.ts",
    "preferences:viz": "node --import tsx src/harness/1-measurement/preferences-viz.ts",
    "consistency:viz": "node --import tsx src/harness/1-measurement/consistency-viz.ts",
    "accuracy:viz": "node --import tsx src/harness/2-accuracy/accuracy-viz.ts",
    "steering": "node --env-file=.env --import tsx src/harness/2-accuracy/steering.ts",
    "threading": "node --env-file=.env --import tsx src/harness/3-tooling/threading.ts",
    "threading:viz": "node --import tsx src/harness/3-tooling/threading-viz.ts",
    "audit:consensus": "node --import tsx src/analysis/consensus-audit.ts",
    "decomposition": "node --env-file=.env --import tsx src/harness/3-tooling/decomposition.ts",
    "fixtures:record": "node --import tsx src/harness/2-accuracy/fixtures.ts record",
    "decomposition:viz": "node --import tsx src/harness/3-tooling/decomposition-viz.ts",
    "analyze:summary": "node --import tsx src/analysis/overview.ts",
    "routing": "node --env-file=.env --import tsx src/harness/4-routing/routing.ts",
    "routing:viz": "node --import tsx src/harness/4-routing/routing-viz.ts",
    "talk": "node --import tsx src/harness/talk-viz.ts",
    "site:assemble": "node --import tsx src/harness/assemble-site.ts",
    "site": "npm run analyze && npm run consistency:viz && npm run preferences:viz && npm run accuracy:viz && npm run threading:viz && npm run decomposition:viz && npm run routing:viz && npm run talk && npm run site:assemble"
  },
  "dependencies": {
    "@mastra/core": "^1.41.0",
    "@mastra/evals": "^1.2.4",
    "@mastra/libsql": "^1.12.1",
    "@mastra/observability": "^1.14.1",
    "chrono-node": "^2.9.1",
    "luxon": "^3.7.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.10.0",
    "alpinejs": "^3.15.12",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
