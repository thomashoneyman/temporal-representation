{
  "name": "temporal-research",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "node --env-file=.env --import tsx src/datasets/seed.ts",
    "phase1": "node --env-file=.env --import tsx src/harness/phase1.ts",
    "phase2": "node --env-file=.env --import tsx src/harness/phase2.ts",
    "phase2:replay": "node --import tsx src/harness/fixtures.ts replay",
    "analyze": "node --import tsx src/analysis/summary.ts && node --import tsx src/analysis/report.ts && node --import tsx src/analysis/summary-viz.ts",
    "dev": "mastra dev",
    "typecheck": "tsc --noEmit",
    "probe": "node --env-file=.env --import tsx src/harness/probe.ts",
    "show-prompt": "node --import tsx src/harness/show-prompt.ts",
    "preferences": "node --env-file=.env --import tsx src/harness/preferences.ts",
    "preferences:viz": "node --import tsx src/harness/preferences-viz.ts",
    "phase1:viz": "node --import tsx src/harness/phase1-viz.ts",
    "phase2:viz": "node --import tsx src/harness/phase2-viz.ts",
    "task5": "node --env-file=.env --import tsx src/harness/task5.ts",
    "task7": "node --env-file=.env --import tsx src/harness/task7.ts",
    "task7:viz": "node --import tsx src/harness/task7-viz.ts",
    "audit:consensus": "node --import tsx src/analysis/consensus-audit.ts",
    "task7b": "node --env-file=.env --import tsx src/harness/task7b.ts",
    "fixtures:record": "node --import tsx src/harness/fixtures.ts record",
    "task7b:viz": "node --import tsx src/harness/task7b-viz.ts",
    "analyze:summary": "node --import tsx src/analysis/summary.ts",
    "task8": "node --env-file=.env --import tsx src/harness/task8.ts",
    "task8:viz": "node --import tsx src/harness/task8-viz.ts",
    "talk": "node --import tsx src/harness/talk-viz.ts",
    "site:assemble": "node --import tsx src/harness/assemble-site.ts",
    "site": "node --import tsx src/analysis/summary.ts && node --import tsx src/analysis/report.ts && node --import tsx src/analysis/summary-viz.ts && node --import tsx src/harness/phase1-viz.ts && node --import tsx src/harness/preferences-viz.ts && node --import tsx src/harness/phase2-viz.ts && node --import tsx src/harness/task7-viz.ts && node --import tsx src/harness/task7b-viz.ts && node --import tsx src/harness/task8-viz.ts && node --import tsx src/harness/talk-viz.ts && node --import tsx src/harness/assemble-site.ts"
  },
  "dependencies": {
    "@mastra/core": "^1.41.0",
    "@mastra/evals": "^1.2.4",
    "@mastra/libsql": "^1.12.1",
    "@mastra/observability": "^1.14.1",
    "chrono-node": "^2.9.1",
    "date-holidays": "^3.30.2",
    "luxon": "^3.7.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.10.0",
    "alpinejs": "^3.15.12",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
